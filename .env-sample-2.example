# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
WEB_APP_URL=https://your-ngrok-or-domain.com   # URL do connect.html

# ─── Stacks — Bot Server (operador) ───────────────────────────
# Única chave privada do sistema. Nunca compartilhe.
AGENT_STACKS_PRIVATE_KEY=              # hex, 64 chars
AGENT_STACKS_ADDRESS=                  # ST... ou SP...
STACKS_NETWORK=testnet                 # mainnet | testnet | devnet
STACKS_EXPLORER_URL=https://explorer.stacks.co/?chain=testnet

# ───  identidade ──────────────────────────────────────
# Salt para derivar telegram-hashes. NUNCA mude após o deploy!
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_HASH_SALT=

# ─── Contracts (após deploy inicial) ──────────────────────────
FACTORY_CONTRACT_ADDRESS=              # ST....wallet-factory

ZEST_CONTRACT=                         # ST....zest-protocol
ALEX_CONTRACT=                         # ST....alex-vault
HERMETICA_CONTRACT=                    # ST....hermetica
BITFLOW_CONTRACT=                      # ST....bitflow-lp

# ─── MCP Server (aibtcdev) ─────────────────────────────────────
AIBTC_MCP_SERVER_PATH=./node_modules/.bin/aibtc-mcp

# ─── x402 ─────────────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.aibtc.com

# ─── Database ─────────────────────────────────────────────────
DB_PATH=./data/copilot.db
