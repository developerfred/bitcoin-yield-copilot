# ── LLM Provider ───────────────────────────────
# Options: 'anthropic' | 'openrouter'
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Telegram ───────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Stacks Network ──────────────────────────────
# Options: 'mainnet' | 'testnet' | 'devnet'
STACKS_NETWORK=testnet
STACKS_API_URL=https://stacks-node-api.testnet.alexlab.co

# ── Agent Wallet ───────────────────────────────
# The deployer wallet that controls the contracts
AGENT_STACKS_PRIVATE_KEY=
AGENT_STACKS_MNEMONIC=
AGENT_STACKS_ADDRESS=
# Salt for deriving telegram hash from user ID
TELEGRAM_HASH_SALT=your-secret-salt-here

# ── Contract Addresses ───────────────────────────
# These contracts must be deployed first
FACTORY_CONTRACT_ADDRESS=
WITHDRAW_HELPER_CONTRACT=

# ── Protocol Adapters (Testnet) ─────────────────
# ALEX Protocol adapters
ADAPTER_ALEX_CONTRACT=

# ── Wallet Connection ───────────────────────────
APP_DOMAIN=https://bitcoin-yield.com
APP_NAME=Bitcoin Yield Copilot
SESSION_DURATION_MS=1800000

# ── MCP Server ─────────────────────────────────
AIBTC_MCP_SERVER_PATH=./node_modules/.bin/aibtc-mcp
# Options: 'mainnet' | 'testnet' | 'devnet'
AIBTC_MCP_NETWORK=testnet

# ── x402 ───────────────────────────────────────
X402_FACILITATOR_URL=https://x402.aibtc.com

# ── ERC-8004 (optional) ────────────────────────
AGENT_IDENTITY_CONTRACT=

# ── Database ────────────────────────────────────
DATABASE_PATH=./data/agent.db
DB_PATH=./data/copilot.db

# ── Logging ────────────────────────────────────
# Options: 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info
