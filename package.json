{
  "name": "bitcoin-yield-copilot",
  "version": "0.0.1",
  "description": "Autonomous Telegram agent that manages Bitcoin yield in the Stacks ecosystem",
  "author": "codingsh",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node dev-orchestrator.mjs",
    "dev:bot": "tsx watch src/index.ts",
    "dev:static": "npx serve public -p 3001 --no-clipboard",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "prepare": "husky"
  },
  "keywords": [
    "bitcoin",
    "stacks",
    "yield",
    "telegram",
    "bot",
    "defi",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aibtc/mcp-server": "^1.28.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@noble/curves": "^2.0.1",
    "@noble/secp256k1": "^3.0.0",
    "@scure/bip39": "^2.0.1",
    "@scure/btc-signer": "^2.0.1",
    "@stacks/connect": "^8.2.5",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "@stacks/wallet-sdk": "^7.2.0",
    "better-sqlite3": "^11.8.1",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "c32check": "^2.0.0",
    "dotenv": "^16.4.7",
    "elliptic": "^6.6.1",
    "grammy": "^1.33.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/deep-eql": "^4.0.2",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "clarinet": "^0.12.6",
    "commitlint": "^19.0.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
