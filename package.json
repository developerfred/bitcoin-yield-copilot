{
  "name": "bitcoin-yield-copilot",
  "version": "0.0.1",
  "description": "Autonomous Telegram agent that manages Bitcoin yield in the Stacks ecosystem",
  "author": "codingsh",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node dev-orchestrator.mjs",
    "dev:bot": "tsx watch src/index.ts",
    "dev:static": "npx serve public -p 3001 --no-clipboard",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:contracts": "node scripts/test-runner.cjs",
    "test:clarinet": "node scripts/test-runner.cjs",
    "test:clarinet:watch": "vitest --config vitest.clarinet.config.ts --watch",
    "test:clarinet:coverage": "vitest --config vitest.clarinet.config.ts --coverage",
    "lint": "eslint src --ext .ts",
    "prepare": "husky"
  },
  "keywords": [
    "bitcoin",
    "stacks",
    "yield",
    "telegram",
    "bot",
    "defi",
    "ai-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@aibtc/mcp-server": "^1.50.1",
    "@anthropic-ai/sdk": "^0.92.0",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@scure/bip39": "^2.2.0",
    "@scure/btc-signer": "^2.2.0",
    "@stacks/clarinet-sdk": "^3.17.0",
    "@stacks/connect": "^8.2.6",
    "@stacks/encryption": "^7.4.0",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "@stacks/wallet-sdk": "^7.2.0",
    "@x402/axios": "^2.11.0",
    "@x402/core": "^2.11.0",
    "@x402/evm": "^2.11.0",
    "@x402/fetch": "^2.11.0",
    "better-sqlite3": "^12.9.0",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "c32check": "^2.0.0",
    "dotenv": "^17.4.2",
    "elliptic": "^6.6.1",
    "express-rate-limit": "^8.3.1",
    "flatted": "^3.4.1",
    "grammy": "^1.42.0",
    "hono": "^4.12.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/deep-eql": "^4.0.2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "clarinet": "^0.12.6",
    "commitlint": "^20.5.3",
    "esbuild": "^0.27.4",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "vitest-environment-clarinet": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "strip-ansi": "^7.0.1",
    "@hono/node-server": "^1.19.11",
    "express-rate-limit": "^8.3.1",
    "flatted": "^3.4.1",
    "hono": "^4.12.8",
    "elliptic": "^6.6.1",
    "esbuild": "^0.27.4"
  }
}